#!/usr/bin/env bash
# This script installs nginx, sets up a web server, and displays “Holberton School” on the main page

# Update package list
sudo apt-get update -y

# Install nginx
sudo apt-get install -y nginx

# Start nginx service
sudo service nginx start

# Create a simple HTML page
echo "Holberton School" | sudo tee /var/www/html/index.html > /dev/null

# Ensure nginx is running and serving content on port 80
sudo service nginx restart
